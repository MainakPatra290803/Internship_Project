# ==================================================
# BACKEND ENVIRONMENT VARIABLES TEMPLATE
# Copy this to .env and fill in values
# DO NOT commit the actual .env to git
# ==================================================

# Database (auto-set by Render, SQLite used locally)
DATABASE_URL=sqlite:///./sql_app.db

# Security - CHANGE THIS in production!
SECRET_KEY=change-this-to-a-random-32-plus-character-string

# Google Gemini AI
GOOGLE_API_KEY=your-google-api-key-here

# Quiz API
QUIZ_API_KEY=your-quiz-api-key-here

# Email Configuration (optional)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# Frontend URL for CORS (set to your deployed frontend URL in production)
# FRONTEND_URL=https://your-app.onrender.com

# Local LLM (leave as false for production - uses Gemini instead)
USE_LOCAL_LLM=false
